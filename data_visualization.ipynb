from matplotlib import colors
import matplotlib.pyplot as plt
import numpy as np

movies_bollywood = ["Jawan","Gadar 2","Pathaan","Stree 2","Animal"]
movies_tollywood = ["Pushpa","RRR","Salaar","Kalki","Devara"]

year1 = [2021,2022,2023,2024,2025]

revenue_bollywood = [640,525,543,1150,550]
revenue_tollywood = [782,859,365,400,600]

x = np.arange(len(year1))
width = 0.35

plt.bar(x - width/2, revenue_bollywood, width, label="Bollywood", color='orange')
plt.bar(x + width/2, revenue_tollywood, width, label="Tollywood", color='blue')

plt.xticks(x, year1)

plt.title("Bollywood vs Tollywood Revenue")
plt.xlabel("Year")
plt.ylabel("Revenue (₹ Crore)")

for i in range(len(year1)):
    plt.text(x[i] - width/2, revenue_bollywood[i], str(revenue_bollywood[i]), ha='center', va='bottom')

for i in range(len(year1)):
    plt.text(x[i] + width/2, revenue_tollywood[i], str(revenue_tollywood[i]), ha='center', va='bottom')

plt.ylim(0, max(max(revenue_bollywood), max(revenue_tollywood)) + 100)

for i in range(len(year1)):
    plt.text(x[i] - width/2, revenue_bollywood[i]/2, movies_bollywood[i],
             ha='center', va='center', rotation=90, color='black')

for i in range(len(year1)):
    plt.text(x[i] + width/2, revenue_tollywood[i]/2, movies_tollywood[i],
             ha='center', va='center', rotation=90, color='white')

plt.legend()
plt.show()

plt.ylim(0, max(max(revenue_bollywood), max(revenue_tollywood)) + 100)

plt.legend()
plt.show()
