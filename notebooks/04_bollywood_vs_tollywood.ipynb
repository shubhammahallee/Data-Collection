import matplotlib.pyplot as plt
import numpy as np

movies_bollywood = ["Jawan","Gadar 2","Pathaan","Stree 2","Animal"]
movies_tollywood = ["Pushpa","RRR","Salaar","Kalki","Devara"]
year1 = [2021, 2022, 2023, 2024, 2025]
revenue_bollywood = [640, 525, 543, 1150, 550]
revenue_tollywood = [782, 859, 365, 400, 600]

x = np.arange(len(year1))
width = 0.35

fig, ax = plt.subplots(figsize=(12, 7))
bars1 = ax.bar(x - width/2, revenue_bollywood, width, label="Bollywood", color='orange',   edgecolor='black')
bars2 = ax.bar(x + width/2, revenue_tollywood, width, label="Tollywood", color='steelblue', edgecolor='black')

# Value labels on top
for bar, val in zip(bars1, revenue_bollywood):
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 10,
            f'₹{val}', ha='center', fontsize=8, fontweight='bold')
for bar, val in zip(bars2, revenue_tollywood):
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 10,
            f'₹{val}', ha='center', fontsize=8, fontweight='bold')

# Movie names inside bars
for i in range(len(year1)):
    ax.text(x[i] - width/2, revenue_bollywood[i]/2, movies_bollywood[i],
            ha='center', va='center', rotation=90, color='black', fontsize=8)
    ax.text(x[i] + width/2, revenue_tollywood[i]/2, movies_tollywood[i],
            ha='center', va='center', rotation=90, color='white', fontsize=8)

ax.set_xticks(x)
ax.set_xticklabels(year1)
ax.set_ylabel("Revenue (₹ Crore)")
ax.set_title("Bollywood vs Tollywood Revenue (2021–2025)", fontsize=13)
ax.set_ylim(0, max(max(revenue_bollywood), max(revenue_tollywood)) + 200)
ax.legend()
ax.grid(axis='y', linestyle='--', alpha=0.5)
plt.tight_layout()
plt.savefig("outputs/bollywood_vs_tollywood.png", dpi=150)
plt.show()
