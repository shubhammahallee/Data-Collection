import matplotlib.pyplot as plt

movies = ["American Beauty","Gladiator","A Beautiful Mind","Chicago",
"The Lord of the Rings: The Return of the King","Million Dollar Baby",
"Crash","The Departed","No Country for Old Men",
"Slumdog Millionaire","The Hurt Locker","The King's Speech",
"The Artist","Argo","12 Years a Slave","Birdman",
"Spotlight","Moonlight","The Shape of Water","Green Book",
"Parasite","Nomadland","CODA","Everything Everywhere All at Once","Oppenheimer"]

revenue = [356.3,460.6,316.8,306.8,1140.7,216.8,
           98.4,291.4,171.6,378.4,49.3,427.4,
           133.4,232.3,187.7,103.2,98.7,65.2,
           195.2,321.8,262.0,39.5,1.9,143.4,958.7]

year = list(range(1999, 2024))

fig, ax = plt.subplots(figsize=(14, 6))
ax.plot(year, revenue, marker='o', color='gold', linewidth=2)

# Highlight top earner
max_idx = revenue.index(max(revenue))
ax.annotate(movies[max_idx],
            xy=(year[max_idx], revenue[max_idx]),
            xytext=(year[max_idx]-3, revenue[max_idx]-150),
            arrowprops=dict(arrowstyle='->', color='red'),
            color='red', fontsize=9)

ax.set_xlabel("Year")
ax.set_ylabel("Revenue (Million $)")
ax.set_title("Oscar Best Picture Revenue (1999–2023)", fontsize=14)
ax.grid(True, linestyle='--', alpha=0.6)
plt.tight_layout()
plt.savefig("outputs/oscar_revenue.png", dpi=150)
plt.show()
