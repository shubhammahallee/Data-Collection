
import matplotlib.pyplot as plt
import matplotlib.patheffects as pe

brands = ["Samsung","Apple","Xiaomi","Realme","Vivo","Oppo","Motorola","Others"]

users_percent = [28,25,15,10,8,7,3,4]

explode = (0,0,0,0,0,0,0.2,0.4)

plt.pie(
    users_percent,
    labels=brands,
    autopct='%1.1f%%',
    wedgeprops={"edgecolor": "black", "linewidth":0.5,"linestyle":" "},
    explode=explode,
    shadow=True,
    startangle=90
)

plt.show()
