from matplotlib import colors
import matplotlib.pyplot as plt
import numpy as np

shows = ["Taarak Mehta Ka Ooltah Chashmah","Anupamaa","Yeh Rishta Kya Kehlata Hai",
"Kumkum Bhagya","Kundali Bhagya","The Kapil Sharma Show",
"Bigg Boss","Naagin","CID","Indian Idol"]

year = [2008,2020,2009,2014,2017,2016,2006,2015,1998,2004]

trp_rating = [2.8,3.5,2.4,2.2,2.3,2.6,2.9,2.7,2.5,2.8]

colors = ["green" if x > 2.7 else "red" for x in trp_rating]

plt.scatter(year, trp_rating, c=trp_rating,  cmap="plasma")
plt.legend()

#for i in range(len(year)):
    #plt.text(year[i], trp_rating[i], shows[i])


plt.xlabel("year")
plt.ylabel("trp_rating")
plt.title("shows vs trp_rating")


for i in range(len(trp_rating)):
    plt.annotate(year[i], xy=(year[i], trp_rating[i]), xytext=(year[i]+0.3, trp_rating[i]+0.05))

plt.xlim(min(year) - 2, max(year) + 5)
plt.ylim(min(trp_rating) - 0.1, max(trp_rating) + 0.1)
plt.grid()
plt.legend()
plt.show()

