import matplotlib.pyplot as plt
import matplotlib.patheffects as pe

shows = ["Taarak Mehta Ka Ooltah Chashmah","Anupamaa","Yeh Rishta Kya Kehlata Hai",
         "Kumkum Bhagya","Kundali Bhagya","The Kapil Sharma Show",
         "Bigg Boss","Naagin","CID","Indian Idol"]

year = [2008,2020,2009,2014,2017,2016,2006,2015,1998,2004]
trp_rating = [2.8,3.5,2.4,2.2,2.3,2.6,2.9,2.7,2.5,2.8]

fig, ax = plt.subplots(figsize=(13, 7))

scatter = ax.scatter(year, trp_rating, c=trp_rating, cmap="plasma", s=150, zorder=3)
plt.colorbar(scatter, ax=ax, label="TRP Rating")

# Custom offsets per label to avoid overlaps
offsets = {
    "Taarak Mehta Ka Ooltah Chashmah": (0, 0.05),
    "Anupamaa":                         (0, 0.05),
    "Yeh Rishta Kya Kehlata Hai":       (0, 0.05),
    "Kumkum Bhagya":                    (0, 0.05),
    "Kundali Bhagya":                   (0, -0.08),
    "The Kapil Sharma Show":            (0, -0.08),
    "Bigg Boss":                        (0, 0.05),
    "Naagin":                           (0, 0.05),
    "CID":                              (0, 0.05),
    "Indian Idol":                      (0, -0.08),
}

for i, show in enumerate(shows):
    dx, dy = offsets[show]
    ax.text(
        year[i] + dx, trp_rating[i] + dy, show,
        fontsize=8.5, ha='center',
        path_effects=[pe.withStroke(linewidth=2, foreground='white')]  # white outline for readability
    )

ax.set_xlabel("Year")
ax.set_ylabel("TRP Rating")
ax.set_title("Shows vs TRP Rating")
ax.set_xlim(1994, 2024)   # padding on both sides
ax.set_ylim(2.05, 3.65)   # padding top and bottom
ax.grid(True, linestyle='--', alpha=0.6)

plt.tight_layout()
plt.show()
