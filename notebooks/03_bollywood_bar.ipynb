import matplotlib.pyplot as plt

movies1 = ["Pushpa: The Rise","RRR","K.G.F: Chapter 2","Jawan","Stree 2"]
year1   = [2021, 2022, 2023, 2024, 2025]
revenue1 = [365, 782, 640, 1150, 600]
colors1  = ['#e63946','#f4a261','#2a9d8f','#457b9d','#e9c46a']

fig, ax = plt.subplots(figsize=(10, 6))
bars = ax.bar(year1, revenue1, color=colors1, edgecolor='black', width=0.5)

for bar, val in zip(bars, revenue1):
    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 20,
            f'₹{val}Cr', ha='center', fontsize=10, fontweight='bold')

ax.set_xticks(year1)
ax.set_xticklabels([f"{y}\n{m}" for y, m in zip(year1, movies1)], fontsize=9)
ax.set_ylabel("Revenue (₹ Crore)")
ax.set_title("Top Bollywood/Tollywood Blockbusters by Year", fontsize=13)
ax.set_ylim(0, max(revenue1) + 200)
ax.grid(axis='y', linestyle='--', alpha=0.5)
plt.tight_layout()
plt.savefig("outputs/bollywood_bar.png", dpi=150)
plt.show()
