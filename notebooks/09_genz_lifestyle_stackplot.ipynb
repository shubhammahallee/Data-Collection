days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]

study = [4, 3.5, 3, 2.5, 2, 1.5, 1]
social_media = [2, 2.5, 3, 3.5, 4, 5, 5.5]
ott = [1, 1.2, 1.5, 2, 2.5, 3, 3.5]
gaming = [1, 1.3, 1.5, 2, 2.5, 3.5, 4]

