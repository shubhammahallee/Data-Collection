import matplotlib.pyplot as plt

# ... (your data lists) ...

fig, ax = plt.subplots(figsize=(14, 6))
ax.plot(year, OSCAR_revenue,     marker='o', label="Oscar Winners",  color='gold',   linewidth=2)
ax.plot(year, NON_OSCAR_revenue, marker='s', label="Non-Oscar",      color='steelblue', linewidth=2)

# Shade the gap
ax.fill_between(year, OSCAR_revenue, NON_OSCAR_revenue, alpha=0.1, color='gray')

ax.set_xlabel("Year")
ax.set_ylabel("Revenue (Million $)")
ax.set_title("Oscar Winners vs Non-Oscar Revenue", fontsize=14)
ax.legend()
ax.grid(True, linestyle='--', alpha=0.6)
plt.tight_layout()
plt.savefig("outputs/oscar_vs_nonoscars.png", dpi=150)
plt.show()
